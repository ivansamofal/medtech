# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=jrnys

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Mammoth EHR
MAMMOTH_API_BASE_URL=https://api.mammoth.com
MAMMOTH_API_LOGIN_EMAIL=your@email.com
MAMMOTH_API_LOGIN_PASSWORD=yourpassword
MAMMOTH_DATA_SAVE_DELAY=5          # seconds (PHP used milliseconds)
MAMMOTH_LAB_RESULTS_DELAY=10       # seconds
MAMMOTH_LAB_RESULTS_PATIENT_DELAY=180  # seconds

# Quest Diagnostics – Booking API
QUEST_BOOKING_BASE_URL=https://booking.questdiagnostics.com
QUEST_BOOKING_AUTHORIZATION_TOKEN=your_token
QUEST_BOOKING_SECRET=your_secret

# Quest Diagnostics – Orders API
QUEST_ORDERS_BASE_URL=https://orders.questdiagnostics.com
QUEST_CLIENT_ID=your_client_id
QUEST_CLIENT_SECRET=your_client_secret
QUEST_ZIP_SEARCH_RADIUS_METERS=16000

# AWS S3 (Quest documents)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=jrnys-quest-docs

# Auth (JWT secret for validating incoming patient tokens)
JWT_SECRET=changeme
